# Runtime
ENVIRONMENT=development
LOG_LEVEL=INFO

# AI runtime
# Leave OPENAI_API_KEY empty to keep the backend in fallback mode.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
ENABLE_MARKETING=true
ENABLE_LIVE_SALES_RESEARCH=true
LIVE_RESEARCH_TIMEOUT_SECONDS=12
PYTHON_VERSION=3.12.8

# Database
# In production or staging, DATABASE_URL must be a PostgreSQL connection string.
# For quick local development you can leave DATABASE_URL empty and use the SQLite fallback below.
DATABASE_URL=
LOCAL_SQLITE_PATH=clinic_copilot.db
AUTO_CREATE_SQLITE_SCHEMA=true

# Frontend and CORS
# Use a comma-separated list of allowed origins.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
FRONTEND_URL=http://localhost:3000

# Optional host filtering for deployed backends.
TRUSTED_HOSTS=
